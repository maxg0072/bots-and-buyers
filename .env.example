# ──────────────────────────────────────────────────────────────────────────
# Bots & Buyers - environment.  Copy this file to `.env` and fill it in.
#   cp .env.example .env
# On Vercel, the Neon integration injects the DB vars automatically; set the
# SESSION_SECRET, ADMIN_EMAILS and ADMIN_TOTP_SECRET yourself.
# ──────────────────────────────────────────────────────────────────────────

# ---- Database (PostgreSQL, e.g. Neon) ----
# The app reads the POOLED connection at runtime and the DIRECT one for migrations.
# Neon's Vercel integration also sets DATABASE_URL / POSTGRES_* automatically.
#   url       -> PRISMA_DATABASE_URL  (pooled; add ?sslmode=require&pgbouncer=true)
#   directUrl -> DATABASE_URL_UNPOOLED (direct; ?sslmode=require)
PRISMA_DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Auth ----
# Session signing secret (HMAC for the login cookie).
# ⚠️ Generate a long random value:  openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string"

# ---- Admin (/admin sales dashboard) ----
# The ONE email allowed admin (first entry). Defaults to max.grau@lio.ai if empty.
ADMIN_EMAILS="max.grau@lio.ai"
# TOTP secret for the admin 2FA code (base32). Generate one + add it to an
# authenticator app. Admin = signed in as the admin email AND a valid code.
ADMIN_TOTP_SECRET="BASE32SECRET"
